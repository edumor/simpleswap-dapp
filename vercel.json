{
  "version": 2,
  "buildCommand": "cd packages/nextjs && npm install && NEXT_PUBLIC_IGNORE_BUILD_ERROR=true npm run build || true",
  "devCommand": "cd packages/nextjs && npm run dev",
  "installCommand": "npm install --prefix packages/nextjs",
  "outputDirectory": "packages/nextjs/out",
  "framework": null,
  "ignoreCommand": "git diff --quiet HEAD^ HEAD ./packages/nextjs/",
  "env": {
    "NEXT_PUBLIC_IGNORE_BUILD_ERROR": "true"
  }
}
