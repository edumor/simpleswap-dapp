# Ejemplo de variables de entorno para el frontend
# Copia este archivo como .env.local y configura los valores

# ============================================
# CONFIGURACIÓN DE RED - SEPOLIA TESTNET
# ============================================

# Red por defecto (Sepolia para demo)
NEXT_PUBLIC_DEFAULT_CHAIN=11155111

# ============================================
# DIRECCIONES DE CONTRATOS EN SEPOLIA
# ============================================

# SimpleSwap Contract
NEXT_PUBLIC_SIMPLE_SWAP_ADDRESS=0x02534A7E22D24F57f53ADe63D932C560a3Cf23f4

# Token A Contract  
NEXT_PUBLIC_TOKEN_A_ADDRESS=0x4efc5e7af7851efB65871c0d54adaC154250126f

# Token B Contract
NEXT_PUBLIC_TOKEN_B_ADDRESS=0x36ae80FDa8f67605aac4Dd723c70ce70513AB909

# ============================================
# API KEYS (OPCIONALES PERO RECOMENDADAS)
# ============================================

# Alchemy API Key para conectar a redes principales
# Obten una gratis en: https://www.alchemy.com/
NEXT_PUBLIC_ALCHEMY_API_KEY=your_alchemy_api_key_here

# WalletConnect Project ID para conectores de wallet
# Obten uno gratis en: https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your_walletconnect_project_id_here

# ============================================
# CONFIGURACIÓN DE BUILD
# ============================================

# URL base para metadatos (opcional)
NEXT_PUBLIC_VERCEL_URL=

# Configuración de build para ignorar errores (solo development)
NEXT_PUBLIC_IGNORE_BUILD_ERROR=false

# ============================================
# URLs ÚTILES PARA SEPOLIA
# ============================================
# Etherscan: https://sepolia.etherscan.io
# Faucet: https://sepoliafaucet.com/
# Chain ID: 11155111
